---
import { render } from "astro:content";
import ArticleShell from "../../components/ArticleShell.astro";
import PageLayout from "../../components/PageLayout.astro";
import { getBlogPosts } from "../../data/posts";
import { withBase } from "../../utils/paths";

export const getStaticPaths = async () => {
  const posts = await getBlogPosts();

  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post }
  }));
};

const { post } = Astro.props;
const { Content } = await render(post);
---

<PageLayout title={`${post.data.title} | yunfie`} description={post.data.description} homeHref="/">
  <ArticleShell
    backHref={withBase("/blog/")}
    backLabel="BLOG"
    date={post.data.date}
    label="Migration Note"
    title={post.data.title}
    lead={post.data.description}
    thumbnail={post.data.thumbnail}
  >
    <Content />
  </ArticleShell>
</PageLayout>
