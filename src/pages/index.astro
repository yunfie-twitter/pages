---
import AboutSection from "../components/AboutSection.astro";
import ContactSection from "../components/ContactSection.astro";
import Hero from "../components/Hero.astro";
import LinksSection from "../components/LinksSection.astro";
import MusicSection from "../components/MusicSection.astro";
import NewsSection from "../components/NewsSection.astro";
import PageLayout from "../components/PageLayout.astro";
import RepositorySection from "../components/RepositorySection.astro";
import { profileLinks } from "../data/links";
import { getBlogPosts } from "../data/posts";
import { withBase } from "../utils/paths";

const posts = await getBlogPosts();
const siteUrl = Astro.site ?? new URL("https://yunfie-twitter.github.io");
const canonicalUrl = new URL(withBase("/"), siteUrl).toString();
const ogImageUrl = new URL(withBase("/ogp.png"), siteUrl).toString();
const description =
  "ゆんふぃの公式ホームページです。YouTube、GitHub、Ko-fi、note、X、Instagram、Misskeyなどの活動リンクをまとめています。";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "ゆんふぃ",
  alternateName: ["Yunfie", "yunfie"],
  url: canonicalUrl,
  sameAs: profileLinks.map((link) => link.url),
  description:
    "ゆんふぃの公式ホームページです。各種SNS・制作活動・投稿サイトへのリンクをまとめています。"
};
---

<PageLayout
  title="ゆんふぃ | Official Website"
  description={description}
  canonicalUrl={canonicalUrl}
  og={{
    siteName: "ゆんふぃ Official Website",
    title: "ゆんふぃ | Official Website",
    description: "ゆんふぃの各種SNS・制作活動・投稿サイトへのリンクをまとめた公式ホームページです。",
    url: canonicalUrl,
    image: ogImageUrl
  }}
  twitter={{
    title: "ゆんふぃ | Official Website",
    description: "ゆんふぃのYouTube、GitHub、Ko-fi、note、X、Instagramなどをまとめたホームページです。",
    image: ogImageUrl,
    site: "@yunfie_misskey",
    creator: "@yunfie_misskey"
  }}
  jsonLd={jsonLd}
>
  <main>
    <Hero />
    <AboutSection />
    <NewsSection posts={posts} />
    <MusicSection />
    <RepositorySection />
    <LinksSection />
    <ContactSection />
  </main>
</PageLayout>
