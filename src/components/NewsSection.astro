---
import { type BlogPost, formatPostDate, getPostHref } from "../data/posts";
import { withBase } from "../utils/paths";

type Props = {
  posts: BlogPost[];
};

const { posts } = Astro.props;
---

<section id="news" class="section">
  <h2>NEWS</h2>

  <p>ブログと更新情報です。</p>

  <div class="news-grid">
    {
      posts.map((post) => (
        <a class="news-card" href={getPostHref(post.id)}>
          <small>{formatPostDate(post.data.date)}</small>
          <span>{post.data.title}</span>
          <p>{post.data.description}</p>
        </a>
      ))
    }
  </div>

  <a class="news-all-link" href={withBase("/blog/")} aria-label="すべての記事を見る">
    すべての記事
  </a>
</section>
