<section id="contact" class="section contact-section">
  <div class="contact-panel">
    <div class="contact-copy">
      <span class="contact-label">CONTACT</span>
      <h2>CONTACT</h2>

      <p>お問い合わせやご連絡は、こちらのメールフォームからお願いします。</p>
      <a class="contact-mail" href="mailto:yunfie168@proton.me">yunfie168@proton.me</a>
    </div>

    <form id="contactForm" class="contact-form">
      <label>
        <span>NAME</span>
        <input name="name" type="text" autocomplete="name" placeholder="お名前" />
      </label>

      <label>
        <span>EMAIL</span>
        <input name="email" type="email" autocomplete="email" placeholder="返信先メールアドレス" />
      </label>

      <label>
        <span>SUBJECT</span>
        <input name="subject" type="text" placeholder="件名" required />
      </label>

      <label>
        <span>MESSAGE</span>
        <textarea name="message" rows="5" placeholder="お問い合わせ内容" required></textarea>
      </label>

      <button class="button contact-submit" type="submit">メールを作成する</button>
    </form>
  </div>
</section>
