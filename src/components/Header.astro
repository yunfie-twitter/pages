---
import { withBase } from "../utils/paths";

const { homeHref = "#home" } = Astro.props;
const normalizedHomeHref = homeHref.startsWith("/") ? withBase(homeHref) : homeHref;
const rootHref = withBase("/");
const sectionPrefix = normalizedHomeHref === "#home" ? "" : rootHref;

const navItems = [
  { href: `${normalizedHomeHref}`, label: "TOP" },
  { href: `${sectionPrefix}#about`, label: "ABOUT" },
  { href: `${sectionPrefix}#news`, label: "NEWS" },
  { href: `${sectionPrefix}#music`, label: "MUSIC" },
  { href: `${sectionPrefix}#repository`, label: "REPOSITORY" },
  { href: `${sectionPrefix}#links`, label: "LINKS" },
  { href: `${sectionPrefix}#contact`, label: "CONTACT" }
];
---

<header class="header">
  <div class="brand-lockup">
    <a class="logo" href={normalizedHomeHref} aria-label="トップページへ戻る">
      <span class="logo-mark" aria-hidden="true">@</span>
      <span class="logo-word">yunfie</span>
    </a>
  </div>

  <button
    class="menu-button"
    id="menuButton"
    type="button"
    aria-label="メニューを開く"
    aria-controls="navMenu"
    aria-expanded="false"
  >
    <span></span>
    <span></span>
    <span></span>
  </button>

  <nav class="nav" id="navMenu" aria-label="メインナビゲーション">
    {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
  </nav>
</header>
