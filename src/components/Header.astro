---
const { homeHref = "#home" } = Astro.props;

const navItems = [
  { href: `${homeHref}`, label: "TOP" },
  { href: `${homeHref === "#home" ? "" : "/"}#about`, label: "ABOUT" },
  { href: `${homeHref === "#home" ? "" : "/"}#news`, label: "NEWS" },
  { href: `${homeHref === "#home" ? "" : "/"}#music`, label: "MUSIC" },
  { href: `${homeHref === "#home" ? "" : "/"}#repository`, label: "REPOSITORY" },
  { href: `${homeHref === "#home" ? "" : "/"}#links`, label: "LINKS" },
  { href: `${homeHref === "#home" ? "" : "/"}#contact`, label: "CONTACT" }
];
---

<header class="header">
  <div class="brand-lockup">
    <a class="logo" href={homeHref} aria-label="トップページへ戻る">
      <span class="logo-mark" aria-hidden="true">@</span>
      <span class="logo-word">yunfie</span>
    </a>
  </div>

  <button
    class="menu-button"
    id="menuButton"
    type="button"
    aria-label="メニューを開く"
    aria-controls="navMenu"
    aria-expanded="false"
  >
    <span></span>
    <span></span>
    <span></span>
  </button>

  <nav class="nav" id="navMenu" aria-label="メインナビゲーション">
    {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
  </nav>
</header>
