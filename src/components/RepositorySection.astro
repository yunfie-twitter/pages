---
import { repositories } from "../data/repositories";
---

<section id="repository" class="section">
  <h2>REPOSITORY</h2>

  <p>公開しているコードや制作物の置き場です。</p>

  {
    repositories.map((repository) => (
      <a
        class="repository-card"
        href={repository.url}
        target="_blank"
        rel="noopener noreferrer me"
        aria-label={repository.label}
      >
        <span class="repository-preview" aria-hidden="true">
          <img src={repository.image} alt="" loading="lazy" width="1200" height="600" />
        </span>
        <span class="repository-copy">
          <small>GitHub</small>
          <strong>{repository.name}</strong>
          <em>{repository.displayUrl}</em>
        </span>
      </a>
    ))
  }
</section>
