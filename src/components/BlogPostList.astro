---
import { type BlogPost, formatPostDate, getPostHref } from "../data/posts";

type Props = {
  posts: BlogPost[];
};

const { posts } = Astro.props;
---

<section class="blog-index section" aria-label="記事一覧">
  <div class="blog-index-head">
    <p class="blog-index-label">Archive</p>
    <p>書いたこと、直したこと、気づいたこと。</p>
  </div>

  <div class="blog-list">
    {
      posts.map((post, index) => (
        <a
          class="blog-post"
          href={getPostHref(post.id)}
          style={`--post-index: '${String(index + 1).padStart(2, "0")}';`}
        >
          <span class="blog-post-meta">
            <time datetime={post.data.date}>{formatPostDate(post.data.date)}</time>
            <span>Note</span>
          </span>
          <span class="blog-post-body">
            <h2>{post.data.title}</h2>
            <p>{post.data.description}</p>
          </span>
          <span class="blog-post-arrow" aria-hidden="true">→</span>
        </a>
      ))
    }
  </div>
</section>
